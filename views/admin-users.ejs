<!DOCTYPE html>
<html>
<head>
    <title>DCI | Staff Management</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body style="background: #0b0e14; padding: 20px;">
    <nav class="navbar">
        <div class="logo">DCI<span>STAFF</span></div>
        <div>
            <a href="/admin" class="btn-cool">Admin Panel</a>
            <a href="/editor" class="btn-cool" style="margin-left:10px;">Editor</a>
            <a href="/logout" style="color:#aaa; margin-left:15px; text-decoration:none;">Logout</a>
        </div>
    </nav>

    <div class="main-container">
        <div class="article-card" style="width: 100%;">
            <h1 style="color: #5865F2;">DCI Staff Management</h1>

            <form action="/admin/users/add" method="POST" style="display:flex; gap:10px; margin-bottom:30px; flex-wrap:wrap;">
                <input type="text" name="username" placeholder="New Username" required style="flex:1; min-width:140px;">
                <input type="password" name="password" placeholder="Password" required style="flex:1; min-width:140px;">
                <select name="role" style="padding:10px; border-radius:4px; background:#111; color:#eee; border:1px solid #333;">
                    <option value="editor">Editor</option>
                    <option value="admin">Admin</option>
                </select>
                <button type="submit" class="btn-cool">Add Staff</button>
            </form>

            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:#111;">
                        <th style="padding:10px; text-align:left; color:#aaa;">Username</th>
                        <th style="padding:10px; text-align:left; color:#aaa;">Role</th>
                        <th style="padding:10px; text-align:left; color:#aaa;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(u => { %>
                        <tr>
                            <td style="padding:10px; border-bottom:1px solid #222; color:#eee;"><%= u.username %></td>
                            <td style="padding:10px; border-bottom:1px solid #222;">
                                <span class="category-tag"><%= u.role %></span>
                            </td>
                            <td style="padding:10px; border-bottom:1px solid #222;">
                                <% if (String(u._id) !== String(user.id)) { %>
                                    <form action="/admin/users/delete/<%= u._id %>" method="POST" onsubmit="return confirm('Revoke access for <%= u.username %>?')">
                                        <button class="btn-delete">Revoke Access</button>
                                    </form>
                                <% } else { %>
                                    <span style="color:#555; font-size:0.85rem;">(you)</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
