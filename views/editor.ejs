<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="/style.css">
    <title>DCI Editor</title>
</head>
<body style="padding: 20px; background: #0b0e14;">
    <nav class="navbar">
        <div class="logo">DCI<span>STUDIOS</span></div>
        <a href="/" class="btn-cool">View Site</a>
        <% if (user && user.role === 'admin') { %>
            <a href="/admin" class="btn-cool" style="margin-left:10px;">Admin Panel</a>
            <a href="/admin/users" class="btn-cool" style="margin-left:10px;">Manage Staff</a>
        <% } %>
        <a href="/logout" style="color:#aaa; margin-left:15px; text-decoration:none;">Logout</a>
    </nav>

    <div class="article-card">
        <h2 style="color: #5865F2;">📊 Analytics & Management</h2>
        <div style="background: #000; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
            <p>Total Articles: <strong><%= stats.total %></strong></p>
            <div style="max-height: 200px; overflow-y: auto;">
                <% stats.recent.forEach(post => { %>
                    <div style="display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid #222;">
                        <span><%= post.title %></span>
                        <form action="/delete/<%= post._id %>" method="POST" style="margin:0;">
                            <button class="btn-delete" onclick="return confirm('Delete this?')">Delete</button>
                        </form>
                    </div>
                <% }) %>
            </div>
        </div>

        <h2 style="color: #5865F2;">✨ Compose News</h2>
        <form action="/api/submit" method="POST">
            <label>Article Title</label>
            <input type="text" name="title" placeholder="Catchy headline..." required>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div>
                    <label>Category</label>
                    <select name="category">
                        <option>Breaking</option>
                        <option>Update</option>
                        <option>Tech & Business Acquisition</option>
                    </select>
                </div>
                <div>
                    <label>Author Display Name</label>
                    <input type="text" name="author" value="Taco">
                </div>
            </div>

            <label>Content (Markdown Supported)</label>
            <textarea name="content" rows="10" placeholder="Write your story here..."></textarea>
            
            <button type="submit" class="btn-cool" style="width: 100%; margin-top: 20px;">🚀 Publish Article</button>
        </form>
    </div>
</body>
</html>
