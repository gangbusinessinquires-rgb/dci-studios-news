<!DOCTYPE html>
<html>
<head>
    <title>DCI | Staff Login</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        .login-box {
            width: 100%;
            max-width: 400px;
            margin: 100px auto;
        }
        input {
            width: 100%;
            padding: 12px;
            margin: 10px 0;
            border: 1px solid #ddd;
            border-radius: 4px;
            box-sizing: border-box; /* Fixes padding overflow */
        }
        .btn-submit {
            background-color: var(--pro-blurple);
            color: white;
            border: none;
            padding: 12px;
            width: 100%;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
        }
        .btn-submit:hover { opacity: 0.9; }
    </style>
</head>
<body>
    <div class="navbar">
        <div>DCI<span>NEWS</span></div>
        <a href="/" style="color: white; text-decoration: none;">← Back to Site</a>
    </div>

    <div class="login-box">
        <div class="article-card">
            <h2 style="text-align: center; margin-bottom: 20px;">Staff Login</h2>
            <% if (locals.error) { %>
                <p style="color: red; text-align: center; margin-bottom: 10px;"><%= error %></p>
            <% } %>
            <form action="/login" method="POST">
                <label>Username</label>
                <input type="text" name="username" placeholder="e.g. taco" required>
                
                <label>Password</label>
                <input type="password" name="password" placeholder="••••••••" required>
                
                <button type="submit" class="btn-submit">Sign In</button>
            </form>
            <p style="font-size: 0.8rem; color: #666; margin-top: 15px; text-align: center;">
                Authorized personnel only.
            </p>
        </div>
    </div>
</body>
</html>

